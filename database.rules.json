{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],

      "$code": {
        ".write": "auth != null",
        ".validate": "$code.matches(/^[A-HJ-NP-Z2-9]{4}$/) && (data.exists() || newData.hasChild('createdAt'))",

        "status": { ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'ready' || newData.val() === 'playing' || newData.val() === 'lobby')" },
        "createdAt": { ".validate": "newData.isNumber() && newData.val() <= now + 60000" },
        "type": { ".validate": "newData.val() === 'tourney'" },

        "host": {
          "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40" },
          "user": { ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_]{3,15}$/) && root.child('usernames').child(newData.val()).val() === auth.uid" },
          "$other": { ".validate": false }
        },
        "guest": {
          "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40" },
          "user": { ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_]{3,15}$/) && root.child('usernames').child(newData.val()).val() === auth.uid" },
          "$other": { ".validate": false }
        },

        "rematch": {
          "$role": { ".validate": "($role === 'host' || $role === 'guest') && newData.isBoolean()" }
        },
        "presence": {
          "$role": { ".validate": "($role === 'host' || $role === 'guest') && newData.isBoolean()" }
        },

        "chat": {
          "$msg": {
            "from": { ".validate": "newData.val() === 'host' || newData.val() === 'guest'" },
            "name": { ".validate": "newData.isString() && newData.val().length <= 40" },
            "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200" },
            "ts": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },

        "game": {
          "board": { ".validate": "newData.isString() && newData.val().length <= 200" },
          "turn": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "mode": { ".validate": "newData.val() === 'single' || newData.val() === 'bo5'" },
          "startedAt": { ".validate": "newData.isNumber()" },
          "moves": {
            "$turn": {
              ".validate": "$turn.matches(/^[0-9]+$/)",
              "$role": {
                ".validate": "$role === 'host' || $role === 'guest'",
                "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                "y": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                "$other": { ".validate": false }
              }
            }
          },
          "duels": {
            "$duelId": {
              ".validate": "$duelId.matches(/^d[0-9]+$/)",
              "$role": {
                ".validate": "$role === 'host' || $role === 'guest'",
                "score": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
                "pos": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
                "$other": { ".validate": false }
              }
            }
          },
          "ejects": {
            "$duelId": {
              ".validate": "$duelId.matches(/^d[0-9]+$/)",
              "youPos": {
                "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                "y": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                "$other": { ".validate": false }
              },
              "oppPos": {
                "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                "y": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                "$other": { ".validate": false }
              },
              "$other": { ".validate": false }
            }
          },
          "$other": { ".validate": false }
        },

        "players": {
          "$seat": {
            ".validate": "$seat.matches(/^s[0-3]$/)",
            "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40" },
            "color": { ".validate": "newData.isString() && newData.val().length <= 30" },
            "uid": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "cpu": { ".validate": "newData.isBoolean()" },
            "user": { ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_]{3,15}$/) && root.child('usernames').child(newData.val()).val() === auth.uid" },
            "$other": { ".validate": false }
          }
        },

        "bracket": {
          "r1": {
            "$mid": {
              ".validate": "$mid === 'm0' || $mid === 'm1'",
              "a": { ".validate": "newData.isString() && newData.val().matches(/^s[0-3]$/)" },
              "b": { ".validate": "newData.isString() && newData.val().matches(/^s[0-3]$/)" },
              "winner": { ".validate": "newData.isString() && newData.val().matches(/^s[0-3]$/)" },
              "$other": { ".validate": false }
            }
          },
          "f": {
            "a": { ".validate": "newData.isString() && newData.val().matches(/^s[0-3]$/)" },
            "b": { ".validate": "newData.isString() && newData.val().matches(/^s[0-3]$/)" },
            "winner": { ".validate": "newData.isString() && newData.val().matches(/^s[0-3]$/)" },
            "$other": { ".validate": false }
          },
          "$other": { ".validate": false }
        },

        "matches": {
          "$mid": {
            ".validate": "$mid === 'm0' || $mid === 'm1' || $mid === 'f'",

            "game": {
              "board": { ".validate": "newData.isString() && newData.val().length <= 200" },
              "turn": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "mode": { ".validate": "newData.val() === 'single' || newData.val() === 'bo5'" },
              "startedAt": { ".validate": "newData.isNumber()" },
              "moves": {
                "$turn": {
                  ".validate": "$turn.matches(/^[0-9]+$/)",
                  "$role": {
                    ".validate": "$role === 'host' || $role === 'guest'",
                    "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                    "y": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                    "$other": { ".validate": false }
                  }
                }
              },
              "duels": {
                "$duelId": {
                  ".validate": "$duelId.matches(/^d[0-9]+$/)",
                  "$role": {
                    ".validate": "$role === 'host' || $role === 'guest'",
                    "score": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
                    "pos": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
                    "$other": { ".validate": false }
                  }
                }
              },
              "ejects": {
                "$duelId": {
                  ".validate": "$duelId.matches(/^d[0-9]+$/)",
                  "youPos": {
                    "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                    "y": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                    "$other": { ".validate": false }
                  },
                  "oppPos": {
                    "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                    "y": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
                    "$other": { ".validate": false }
                  },
                  "$other": { ".validate": false }
                }
              },
              "$other": { ".validate": false }
            },

            "presence": {
              "$role": { ".validate": "($role === 'host' || $role === 'guest') && newData.isBoolean()" }
            },
            "rematch": {
              "$role": { ".validate": "($role === 'host' || $role === 'guest') && newData.isBoolean()" }
            },
            "chat": {
              "$msg": {
                "from": { ".validate": "newData.val() === 'host' || newData.val() === 'guest'" },
                "name": { ".validate": "newData.isString() && newData.val().length <= 40" },
                "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200" },
                "ts": { ".validate": "newData.isNumber()" },
                "$other": { ".validate": false }
              }
            },
            "spec": {
              "note": { ".validate": "newData.val() === 'cpu'" },
              "board": { ".validate": "newData.isString() && newData.val().length <= 200" },
              "turn": { ".validate": "newData.isNumber()" },
              "A": {
                "x": { ".validate": "newData.isNumber()" },
                "y": { ".validate": "newData.isNumber()" },
                "hp": { ".validate": "newData.isNumber()" },
                "$other": { ".validate": false }
              },
              "B": {
                "x": { ".validate": "newData.isNumber()" },
                "y": { ".validate": "newData.isNumber()" },
                "hp": { ".validate": "newData.isNumber()" },
                "$other": { ".validate": false }
              },
              "duel": {
                "active": { ".validate": "newData.isBoolean()" },
                "winner": { ".validate": "newData.isString() && (newData.val()==='A' || newData.val()==='B' || newData.val()==='tie')" },
                "scoreA": { ".validate": "newData.isNumber()" },
                "scoreB": { ".validate": "newData.isNumber()" },
                "$other": { ".validate": false }
              },
              "$other": { ".validate": false }
            },
            "result": {
              "winner": { ".validate": "newData.isString() && newData.val().matches(/^s[0-3]$/)" },
              "$other": { ".validate": false }
            },
            "$other": { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid",
        "stats": {
          "$statKey": {
            ".validate": "$statKey.matches(/^(gamesPlayed|gamesWon|kills|tournamentsWon|damageDealt|damageReceived)$/) && newData.isNumber() && newData.val() >= 0"
          }
        },
        "skin": { ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_]{1,20}$/)" },
        "tourneyProgress": {
          "$idx": { ".validate": "$idx.matches(/^[0-9]{1,2}$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000" }
        }
      }
    },

    "usernames": {
      ".read": "auth != null",
      "$uname": {
        ".write": "auth != null && !data.exists() && newData.val() === auth.uid",
        ".validate": "$uname.matches(/^[a-z0-9_]{3,15}$/) && newData.isString()"
      }
    },

    "config": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$param": {
        ".validate": "$param.matches(/^[A-Za-z]{1,40}$/) && newData.isNumber()"
      }
    },

    "texts": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$key": {
        ".validate": "$key.matches(/^[A-Za-z0-9]{1,40}$/) && newData.isString() && newData.val().length <= 2000"
      }
    },

    "campaign": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "script": {
        ".validate": "newData.isString() && newData.val().length <= 200000"
      },
      "$other": { ".validate": false }
    },

    "maps": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$id": {
        ".validate": "$id.matches(/^[A-Za-z0-9_-]{1,40}$/) && newData.isString() && newData.val().length <= 8000"
      }
    },

    "characters": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "roster": {
        ".validate": "newData.isString() && newData.val().length <= 8000"
      },
      "$other": { ".validate": false }
    },

    "admins": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && newData.val() === true && ((auth.uid === $uid && !root.child('admins').exists()) || root.child('admins').child(auth.uid).val() === true)"
      }
    },

    "siteStats": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "pageViews": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "visitors": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isBoolean() && newData.val() === true"
        }
      }
    }
  }
}
